R2_ENDPOINT = "https://<ACCOUNT_ID>.r2.cloudflarestorage.com"
R2_ACCESS_KEY = "<R2_ACCESS_KEY>"
R2_SECRET_KEY = "<R2_SECRET_KEY>"
BUCKET_NAME = "<BUCKET_NAME>"

# Account amministratore. Non salvare mai la password reale su GitHub.
ADMIN_USERNAME = "Admin"
ADMIN_PASSWORD = "<PASSWORD_FORTE>"

# L'elenco iniziale viene importato nel registro dinamico su R2.
AUTHORIZED_EMAILS = ["utente@esempio.com"]

# Il mittente visibile è fissato nel codice a simone.terrani@philips.com.
OTP_SENDER_NAME = "Philips Spectral CT Webinar"
SMTP_HOST = "smtp.office365.com"
SMTP_PORT = 587
SMTP_USERNAME = "simone.terrani@philips.com"
SMTP_PASSWORD = "<PASSWORD_O_APP_PASSWORD>"
SMTP_USE_SSL = false
SMTP_USE_STARTTLS = true
